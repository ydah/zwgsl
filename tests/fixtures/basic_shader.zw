version "300 es"
precision :fragment, :highp

uniform :mvp, Mat4
uniform :base_color, Vec4

vertex do
  input :position, Vec3, location: 0
  varying :v_pos, Vec3

  def main
    self.v_pos = position
    gl_Position = mvp * vec4(position, 1.0)
  end
end

fragment do
  varying :v_pos, Vec3
  output :frag_color, Vec4, location: 0

  def main
    frag_color = vec4(v_pos, base_color.a)
  end
end
