version "300 es"
precision :fragment, :highp

uniform :mvp, Mat4

vertex do
  input :position, Vec3, location: 0
  input :color, Vec3, location: 1
  varying :v_color, Vec3

  def main
    self.v_color = color
    gl_Position = mvp * vec4(position, 1.0)
  end
end

fragment do
  varying :v_color, Vec3
  output :frag_color, Vec4, location: 0

  def main
    frag_color = vec4(v_color, 1.0)
  end
end
